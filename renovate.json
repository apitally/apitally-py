{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>apitally/renovate-config"],
  "ignoreDeps": ["pytest-asyncio"],
  "packageRules": [
    {
      "matchPackageNames": ["pytest"],
      "allowedVersions": "<9"
    },
    {
      "matchPackageNames": ["pytest-httpx"],
      "allowedVersions": "<0.36"
    }
  ]
}
